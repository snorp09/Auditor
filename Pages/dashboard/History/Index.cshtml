@page
@model Auditor.Pages.Dashboard.History.IndexModel
@{
    ViewData["title"] = "History";
    Layout = "_DashLayout";
}

<div class="d-flex flex-column my-2">
    <h1 class="h4">History</h1>
    <h1 class="h6 text-muted">View Past Month Transactions</h1>
</div>

<div class="d-flex flex-column p-4 border rounded">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h4">@Model.month.ToString("MMMM yyyy")</h1>
        <div class="d-flex gap-2">
            <form method="get">
                <button type="submit" name="month" value="@Model.month.AddMonths(-1).ToString("yyyy-MM")" class="btn btn-outline-primary"><i class="ph ph-arrow-left"></i></button>
            </form>
            <form method="get">
                <button type="submit" name="month" value="@Model.month.AddMonths(1).ToString("yyyy-MM")" class="btn btn-outline-primary" @(Model.month >= DateTime.Now.AddMonths(-1) ? "disabled" : "")><i class="ph ph-arrow-right"></i></button>
            </form>
        </div>
    </div>
    <div class="overflow-auto" style="max-height: 400px;">
        <table class="table table-striped">
            <thead class="sticky-top bg-white">
                <tr>
                    <th>Name</th>
                    <th>Amount</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var transaction in Model.Transactions)
                {
                    <tr>
                        <td>@transaction.Name</td>
                        <td>@transaction.Amount</td>
                        <td>@transaction.Date.ToString("yyyy-MM-dd")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>